# Odoo Configuration
ODOO_HOST=localhost
ODOO_PORT=8069
ODOO_PROTOCOL=jsonrpc
ODOO_DB=uaau
ODOO_USER=admin@uaau.com
ODOO_PASSWORD=password

# AI Agents Worker Pool
# Insira os IDs dos Employees (Funcionários) no Odoo que serão usados como robôs
# O seu usuário principal (admin) deve ser o Gerente (Manager) deles no Odoo
AI_AGENT_IDS=2,3,4

# AI API Keys (optional - use whichever you need)
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# Sync Configuration
DEFAULT_PROJECT_ID=1
DEFAULT_USER_ID=2
SYNC_INTERVAL=300
AUTO_SYNC=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/odoo_sync.log
