# Odoo Configuration
ODOO_HOST=your-odoo-vps.com
ODOO_PORT=443
ODOO_PROTOCOL=jsonrpc+ssl
ODOO_DB=odoo
ODOO_USER=your.email@example.com
ODOO_PASSWORD=your_password

# AI API Keys (optional - use whichever you need)
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# Sync Configuration
DEFAULT_PROJECT_ID=1
DEFAULT_USER_ID=2
SYNC_INTERVAL=300
AUTO_SYNC=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/odoo_sync.log
